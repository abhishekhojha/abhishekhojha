---
import { Github, Mail, Download, ArrowUpRight } from "lucide-react";

const currentYear = new Date().getFullYear();

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/learnings", label: "Learnings" },
  { href: "/contact", label: "Contact" },
  { href: "/abhishekh-ojha", label: "About" },
];

const socialLinks = [
  {
    href: "https://github.com/abhishekhojha",
    label: "GitHub",
    icon: "github",
    external: true,
  },
  {
    href: "mailto:oabhishekh8@gmail.com",
    label: "Email",
    icon: "mail",
    external: false,
  },
  {
    href: "https://www.linkedin.com/in/abhishekhojha/",
    label: "LinkedIn",
    icon: "linkedin",
    external: true,
  },
];
---

<footer
  class="relative border-t border-gray-200 dark:border-gray-800 bg-[#f6f6f6] dark:bg-[#0f0f0f] overflow-hidden"
>
  {/* Gradient accent line at top */}
  <div
    class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-indigo-500/50 to-transparent"
  >
  </div>

  {/* Subtle radial glow in background */}
  <div
    class="pointer-events-none absolute inset-0 flex items-center justify-center"
  >
    <div
      class="w-[600px] h-[300px] rounded-full bg-indigo-500/5 dark:bg-indigo-500/10 blur-3xl"
    >
    </div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 py-12 md:py-16 relative z-10">
    {/* Top section */}
    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6 pb-10 border-b border-gray-200 dark:border-gray-800"
    >
      {/* Brand column */}
      <div class="flex flex-col gap-4">
        <div class="flex items-center gap-2">
          <span
            class="inline-flex items-center gap-1.5 text-xs font-medium text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-full px-2.5 py-1"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"
            ></span>
            Open to opportunities
          </span>
        </div>
        <h2
          class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-gray-100 tracking-tight leading-tight"
        >
          Abhishekh Ojha
        </h2>
        <p
          class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed max-w-xs"
        >
          Software Engineer crafting scalable web apps & AI automation
          workflows. Based in Indore, India.
        </p>
        {/* CTA */}
        <a
          href="mailto:oabhishekh8@gmail.com"
          class="inline-flex items-center gap-2 w-fit text-sm font-semibold text-gray-900 dark:text-gray-100 bg-gray-900/5 dark:bg-white/10 hover:bg-gray-900/10 dark:hover:bg-white/15 border border-gray-200 dark:border-gray-700 rounded-full px-4 py-2 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md group"
        >
          <Mail className="w-3.5 h-3.5 text-indigo-500" strokeWidth={2} />
          Let's work together
          <ArrowUpRight
            className="w-3 h-3 opacity-50 group-hover:opacity-100 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-200"
            strokeWidth={2}
          />
        </a>
      </div>

      {/* Navigation column */}
      <div class="flex flex-col gap-4">
        <p
          class="text-xs font-semibold uppercase tracking-[0.15em] text-gray-400 dark:text-gray-500"
        >
          Navigation
        </p>
        <nav class="flex flex-col gap-2">
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                class="group flex items-center gap-2 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors duration-200 w-fit"
              >
                <span class="w-0 h-px bg-gradient-to-r from-indigo-500 to-purple-500 group-hover:w-4 transition-all duration-300 rounded-full" />
                {link.label}
              </a>
            ))
          }
        </nav>
      </div>

      {/* Connect column */}
      <div class="flex flex-col gap-4">
        <p
          class="text-xs font-semibold uppercase tracking-[0.15em] text-gray-400 dark:text-gray-500"
        >
          Connect
        </p>
        <div class="flex flex-col gap-3">
          {/* GitHub */}
          <a
            href="https://github.com/abhishekhojha"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-3 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors duration-200 w-fit"
          >
            <span
              class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-gray-100 dark:bg-gray-800 group-hover:bg-gray-200 dark:group-hover:bg-gray-700 transition-colors duration-200"
            >
              <Github className="w-3.5 h-3.5" strokeWidth={2} />
            </span>
            GitHub
            <ArrowUpRight
              className="w-3 h-3 opacity-0 group-hover:opacity-60 transition-opacity duration-200"
              strokeWidth={2}
            />
          </a>

          {/* LinkedIn */}
          <a
            href="https://www.linkedin.com/in/abhishekhojha/"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-3 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors duration-200 w-fit"
          >
            <span
              class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-gray-100 dark:bg-gray-800 group-hover:bg-gray-200 dark:group-hover:bg-gray-700 transition-colors duration-200"
            >
              {/* LinkedIn icon */}
              <svg
                class="w-3.5 h-3.5"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
            </span>
            LinkedIn
            <ArrowUpRight
              className="w-3 h-3 opacity-0 group-hover:opacity-60 transition-opacity duration-200"
              strokeWidth={2}
            />
          </a>

          {/* Email */}
          <a
            href="mailto:oabhishekh8@gmail.com"
            class="group flex items-center gap-3 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors duration-200 w-fit"
          >
            <span
              class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-gray-100 dark:bg-gray-800 group-hover:bg-gray-200 dark:group-hover:bg-gray-700 transition-colors duration-200"
            >
              <Mail className="w-3.5 h-3.5" strokeWidth={2} />
            </span>
            oabhishekh8@gmail.com
          </a>

          {/* Resume */}
          <a
            href="/ABHISHEKH_OJHA.pdf"
            download="ABHISHEKH_OJHA.pdf"
            class="group flex items-center gap-3 text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors duration-200 w-fit"
          >
            <span
              class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-gray-100 dark:bg-gray-800 group-hover:bg-gray-200 dark:group-hover:bg-gray-700 transition-colors duration-200"
            >
              <Download className="w-3.5 h-3.5" strokeWidth={2} />
            </span>
            Download Resume
          </a>
        </div>
      </div>
    </div>

    {/* Bottom bar */}
    <div
      class="pt-6 flex flex-col sm:flex-row items-center justify-center gap-4"
    >
      <p class="text-xs text-gray-400 dark:text-gray-500">
        &copy; {currentYear} Abhishekh Ojha. All rights reserved.
      </p>
      <!-- <p class="text-xs text-gray-400 dark:text-gray-500 flex items-center gap-1">
        Built with
        <span
          class="bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 bg-clip-text text-transparent font-semibold"
          >Astro</span
        > &amp;
        <span class="text-gray-900 dark:text-white font-semibold"
          >passion</span
        >
      </p> -->
    </div>
  </div>
</footer>
